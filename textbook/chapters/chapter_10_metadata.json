    {
      "bloom_level": "Analyze",
      "text": "Analyze the global epidemiology of HIV, viral hepatitis, and bacterial STIs across different populations and geographic contexts"
    },
    {
      "bloom_level": "Evaluate",
      "text": "Evaluate the effectiveness of combination prevention strategies including behavioral, biomedical, and structural interventions for STI and HIV control"
    },
    {
      "bloom_level": "Apply",
      "text": "Apply harm reduction principles to design context-appropriate interventions for key populations at elevated risk"
    },
    {
      "bloom_level": "Create",
      "text": "Design integrated sexual and reproductive health programs that address STI prevention, treatment, and stigma reduction"
    },
    {
      "bloom_level": "Evaluate",
      "text": "Critically evaluate human rights-based approaches to infectious disease control and their impact on health outcomes"
    },
    {
      "bloom_level": "Analyze",
      "text": "Analyze the biological, social, and structural factors contributing to antimicrobial resistance in sexually transmitted infections"
    }

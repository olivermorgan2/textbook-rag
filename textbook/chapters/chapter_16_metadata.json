  "assessment_materials": {
    "multiple_choice_questions": {
      "count": 2,
      "items": [
        {
          "question_id": "MCQ-16.1",
          "question": "According to the WHO mhGAP program, which approach is most effective for scaling mental health services in low-resource settings?",
          "options": [
            "A) Increasing the number of psychiatrists",
            "B) Task-shifting to non-specialist healthcare workers",
            "C) Building more specialized mental health facilities",
            "D) Focusing only on severe mental disorders"
          ],
          "correct_answer": "B",
          "explanation": "Task-shifting to trained non-specialist providers is the cornerstone of mhGAP, allowing for scalable mental health service delivery in resource-constrained settings.",
          "learning_objective": "LO-16.3"
        },
        {
          "question_id": "MCQ-16.2",
          "question": "Which suicide prevention strategy has shown the strongest evidence for population-level impact?",
          "options": [
            "A) Individual counseling programs",
            "B) Media reporting guidelines",
            "C) Means restriction policies",
            "D) School-based awareness programs"
          ],
          "correct_answer": "C",
          "explanation": "Means restriction, such as limiting access to pesticides and firearms, has demonstrated the most robust evidence for reducing suicide rates at the population level.",
          "learning_objective": "LO-16.4"
        }
      ]
    },

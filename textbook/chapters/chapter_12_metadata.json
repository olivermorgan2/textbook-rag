  "assessment_materials": {
    "multiple_choice_questions": {
      "count": 3,
      "items": [
        {
          "question_id": "MCQ12.1",
          "question": "Which intervention has shown the greatest population-level impact in reducing cardiovascular disease mortality in low and middle-income countries?",
          "options": [
            "A) Percutaneous coronary intervention programs",
            "B) Population-wide salt reduction strategies",
            "C) Individual risk factor counseling",
            "D) Cardiac rehabilitation programs"
          ],
          "correct_answer": "B",
          "explanation": "Population-wide salt reduction strategies have demonstrated the greatest impact on CVD mortality at the population level, with modeling studies showing potential prevention of millions of deaths globally through sodium reduction policies.",
          "learning_objective": "Evaluate the cost-effectiveness and population impact of cardiovascular disease prevention strategies"
        },
        {
          "question_id": "MCQ12.2",
          "question": "The WHO HEARTS technical package for cardiovascular disease management in primary care emphasizes which key components?",
          "options": [
            "A) Healthy lifestyle counseling, Evidence-based protocols, Access to medicines, Risk-based care, Team care, Systems for monitoring",
            "B) Hospital-based care, Expensive technologies, Advanced procedures, Risk stratification, Tertiary prevention, Specialist referrals",
            "C) Individual counseling only, Medication management, Acute care, Rehabilitation, Telemedicine, Surgery",
            "D) Health education, Emergency response, Ambulatory care, Routine screening, Treatment protocols, Surveillance only"
          ],
          "correct_answer": "A",
          "explanation": "The WHO HEARTS package emphasizes six key components represented by the acronym HEARTS: Healthy lifestyle counseling, Evidence-based protocols, Access to essential medicines, Risk-based CVD management, Team-based care, and Systems for monitoring.",
          "learning_objective": "Design comprehensive hypertension control programs adapted to different health system contexts"
        },
        {
          "question_id": "MCQ12.3",
          "question": "According to the Global Burden of Disease study, which factor contributes most significantly to the global burden of cardiovascular disease?",
          "options": [
            "A) Air pollution",
            "B) High blood pressure",
            "C) Tobacco use",
            "D) Physical inactivity"
          ],
          "correct_answer": "B",
          "explanation": "High blood pressure is the leading risk factor for cardiovascular disease globally, accounting for approximately 19% of all CVD deaths and being responsible for the largest number of disability-adjusted life years (DALYs) attributable to CVD.",
          "learning_objective": "Analyze global cardiovascular disease burden patterns and epidemiological transitions"
        }
      ]
    },
